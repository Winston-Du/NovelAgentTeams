.DS_Store
**/.DS_Store
__pycache__/
*.pyc
.env
*.sqlite3
vector_db/

# First/ 目录只保留目录结构，不保留内容
First/*
!First/.gitkeep

# novels_project/output/ 目录只保留目录结构，不保留内容
novels_project/output/*
!novels_project/output/.gitkeep

# 小说内容相关的私密文件（精确匹配）
novels_project/src/novels_project/config/character_base_cards.yaml
novels_project/docs/character_cards.md

# feedback/ 和 knowledge/ 目录级忽略（避免遗漏新增文件）
novels_project/feedback/
novels_project/knowledge/

# 图谱同步状态文件（运行时生成）
**/.graph_sync_state.json

# 本地小说内容已迁移到独立目录，忽略子目录（如存在）
novel_xuanhuan_output/

# 工作空间目录 - 存储用户小说项目，不应上传到 GitHub
workspaces/

# 工作空间注册表
novels_project/workspaces_registry/

# AI 工具本地配置与 IDE 配置
.kilocode/
.trae/
.workbuddy/
.vscode/

# ============================================================
# macOS / Windows 系统文件
# ============================================================
.DS_Store
**/.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ============================================================
# Python 通用（覆盖整个 monorepo）
# ============================================================
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.Python
build/
develop-eggs/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.so
.installed.cfg
*.egg

# 虚拟环境
venv/
env/
ENV/
.venv/
.env-*/

# 测试 / 覆盖率
.pytest_cache/
**/.pytest_cache/
.coverage
**/.coverage
coverage.xml
coverage.json
htmlcov/
.tox/
.mypy_cache/
.ruff_cache/
.cache/

# 分布式 / 实验产物
*.sqlite3
*.db
*.sqlite
vector_db/
**/vector_db/

# ============================================================
# Node / Frontend 通用（每个 frontend 子项目另有 .gitignore）
# ============================================================
node_modules/
**/node_modules/
.pnp
.pnp.js
*.tsbuildinfo
.npm
.eslintcache
.stylelintcache
.parcel-cache/

# ============================================================
# 临时 / 备份
# ============================================================
*.bak
*.swp
*~
*.tmp
*.temp
*.orig
*.rej
.cache/
.tmp/
tmp/

# ============================================================
# IDE
# ============================================================
.idea/
*.iml
*.ipr
*.iws
.vscode/*
!.vscode/extensions.json
.atomic-completion.tmp
