# ============================================================
# Frontend .gitignore
# 适用于 Vite + React + TypeScript + Vitest + Ant Design
# ============================================================

# Dependencies
node_modules/
.pnp
.pnp.js

# Build outputs
dist/
build/
out/
*.tsbuildinfo

# Vite cache
.vite/
.vite-cache/

# Vitest cache & coverage
coverage/
.nyc_output/
*.lcov

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log

# Editor / OS
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.bak
*~
.eslintcache
.stylelintcache
.parcel-cache/

# Env / secrets
.env
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local

# Test artifacts
test-results/
playwright-report/
playwright/.cache/

# Misc
node/
jspm_packages/
.cache/
